# .env.sample — copy to .env and fill in your values

# URL users use to access the app in their browser (must match exactly for auth to work)
CORS_ORIGIN=http://localhost:8080

# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-string

# Optional overrides
# PORT=8080
# CONFIG_DIR=./config
# DATA_DIR=./data
